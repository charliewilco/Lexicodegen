public struct ATProtocolDynamicCodingKey: CodingKey {
    public let stringValue: String
    public let intValue: Int?

    public init?(stringValue: String) {
        self.stringValue = stringValue
        self.intValue = nil
    }

    public init?(intValue: Int) {
        self.stringValue = String(intValue)
        self.intValue = intValue
    }
}

public enum NotImplementedError: Error {
    case unsupported
}

public protocol LexiconTransport {
    func execute<T: Decodable>(method: String, path: String, body: Data?) async throws -> T
}

public final class XRPCClient {
    private let transport: LexiconTransport?
    private let encoder: JSONEncoder

    public init(transport: LexiconTransport? = nil, encoder: JSONEncoder = JSONEncoder()) {
        self.transport = transport
        self.encoder = encoder
    }

    public func request<T: Decodable>(
        method: String,
        path: String,
        body: Data? = nil,
    ) async throws -> T {
        guard let transport else {
            throw NotImplementedError.unsupported
        }
        return try await transport.execute(method: method, path: path, body: body)
    }

    public func encodedBody<T: Encodable>(_ value: T?) throws -> Data? {
        guard let value else {
            return nil
        }
        return try encoder.encode(value)
    }
}
