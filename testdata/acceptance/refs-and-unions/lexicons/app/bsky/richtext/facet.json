{
	"lexicon": 1,
	"id": "app.bsky.richtext.facet",
	"defs": {
		"main": {
			"type": "object",
			"required": ["index", "features"],
			"properties": {
				"index": { "type": "ref", "ref": "#byteSlice" },
				"features": {
					"type": "array",
					"items": { "type": "union", "refs": ["#mention", "#link", "#tag"] }
				}
			}
		},
		"mention": {
			"type": "object",
			"required": ["did"],
			"properties": {
				"did": { "type": "string", "format": "did" }
			}
		},
		"link": {
			"type": "object",
			"required": ["uri"],
			"properties": {
				"uri": { "type": "string" }
			}
		},
		"tag": {
			"type": "object",
			"required": ["tag"],
			"properties": {
				"tag": { "type": "string" }
			}
		},
		"byteSlice": {
			"type": "object",
			"required": ["byteStart", "byteEnd"],
			"properties": {
				"byteStart": { "type": "integer" },
				"byteEnd": { "type": "integer" }
			}
		}
	}
}
