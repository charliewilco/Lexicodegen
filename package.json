{
	"name": "lexicodegen",
	"module": "main.ts",
	"type": "module",
	"bin": {
		"lexicodegen": "./main.ts"
	},
	"private": true,
	"scripts": {
		"build": "bun build ./main.ts --target bun --outfile ./dist/main.mjs",
		"generate": "bun ./main.ts ./lexicons --output ./output/swift",
		"check:swift": "bash ./scripts/check-swift-compile.sh ./output/swift",
		"verify:swift": "bun run generate && bun run check:swift",
		"postgenerate": "bunx biome format --write ./output/**/*.swift ./lexicons/**/**/**/*.json",
		"dev": "bun --watch run ./main.ts",
		"test": "bun test",
		"test:ci": "bun test --coverage"
	},
	"dependencies": {
		"@atproto/lexicon": "^0.6.2",
		"ejs": "5.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/bun": "latest",
		"@types/ejs": "3.1.5",
		"lefthook": "^2.0.8",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"typescript": "^6"
	},
	"packageManager": "bun@1.3.9"
}
