{
	"name": "lexicodegen",
	"module": "main.ts",
	"type": "module",
	"bin": {
		"lexicodegen": "./lexicodegen"
	},
	"private": true,
	"scripts": {
		"build": "bun build --compile --minify --outfile ./lexicodegen ./main.ts",
		"generate": "./lexicodegen ./lexicons --output ./output/swift",
		"postgenerate": "bunx biome format --write ./output/**/*.swift ./lexicons/**/**/**/*.json",
		"dev": "bun --watch run ./main.ts",
		"test": "bun test",
		"test:ci": "bun test --coverage"
	},
	"dependencies": {
		"@atproto/lexicon": "^0.6.1",
		"ejs": "4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/bun": "latest",
		"@types/ejs": "3.1.5",
		"lefthook": "^2.0.8"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.9"
}
