{
	"name": "lexicon-openapi-generator",
	"module": "main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun run ./main.ts",
		"postbuild": "bunx biome format --write ./output/*.json ./lexicons/**/**/**/*.json",
		"dev": "bun --watch run ./main.ts"
	},
	"dependencies": {
		"@atproto/lexicon": "^0.4.10",
		"openapi-types": "^12.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/bun": "latest",
		"lefthook": "^2.0.8"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
